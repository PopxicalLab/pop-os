// ───────────────────────────────────────────────────────────────
// Pop OS — Prisma schema
// This file is the SINGLE source of truth for your database shape.
// You edit this file, then run `npx prisma migrate dev` and Prisma
// builds/updates the real PostgreSQL tables to match.
// ───────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // read from the .env file
}

// ── COMPANY ─────────────────────────────────────────────────────
// The two studios that make up Pop Group.
enum Company {
  LPS // Lorrypop Studio
  PXL // Popxical Lab
}

// ── CAPACITY ENUM ───────────────────────────────────────────────
// Whether the person is the primary owner of the project week or a
// supporting hand. Convention: Main = 70–80%, Support = 20–30%.
enum CapacityRole {
  MAIN
  SUPPORT
}

// ── PROJECT ENUMS ────────────────────────────────────────────────
// Which quadrant a project sits in (PPM framework).
// DRAIN = low budget / high complexity — needs two-signature approval.
enum ProjectQuadrant {
  GOLD
  STRATEGIC_BET
  OPERATIONAL_FILLER
  DRAIN
}

// How urgently the studio is treating this project.
enum ProjectPriority {
  P1
  P2
  P3
}

// How established the client relationship is.
// Used as one input to the PPM quadrant/priority recommendation engine.
enum ClientTier {
  NEW
  RETURNING
  KEY_ACCOUNT
}

// Where the project is in its lifecycle.
enum ProjectStatus {
  BRIEF
  IN_PROGRESS
  INTERNAL_REVIEW
  DELIVERED
  ON_HOLD
  CANCELLED
}

// Employment type — restricted to a fixed set of values.
// (This is the Prisma way of doing a dropdown / "enum".)
enum EmploymentType {
  FULL_TIME
  CONTRACT
  FREELANCE
  INTERN
}

// Where a skill-rating change came from.
// INTERVIEW is the very first entry (candidate stage); the others
// happen after hire and can move a score up or down.
enum RatingSource {
  INTERVIEW
  PROJECT_COMPLETION
  MANUAL_ADJUSTMENT
}

// ── PEOPLE / ELC ────────────────────────────────────────────────
// One record per person. This is the foundation of the whole system:
// Projects, Capacity, and Assets will all link back to a Person.
model Person {
  id             String         @id @default(cuid())
  name           String
  role           String         // e.g. "3D Artist", "Producer", "PM"
  department     String         // e.g. "3D", "Art", "Production"
  startDate      DateTime
  employmentType EmploymentType @default(FULL_TIME)
  warmPool       Boolean        @default(false) // true = in the Warm Talent Pool (alumni/rejected/freelance)
  company        Company?       // LPS or PXL — optional so existing records are unaffected
  salary         Float?         // monthly salary in RM — used by the Financial Engine for man-day costing

  // A person's rated skills (the live current scores).
  skills             PersonSkill[]

  // Projects this person is responsible for (as producer or PM).
  projectsAsProducer Project[]    @relation("ProducerProjects")
  projectsAsPM       Project[]    @relation("PMProjects")

  // Weekly capacity allocations across projects.
  capacityEntries    Capacity[]

  // Leads this person closed (as the winning or losing salesperson).
  leadsWon           Lead[]      @relation("LeadClosedBy")

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

// ── SKILL ───────────────────────────────────────────────────────
// The studio's master list of skills. Keeping these as their own
// records (instead of free-typed text) means "Rigging" is always
// spelled the same and you can ask "who is strong at Rigging?".
model Skill {
  id        String        @id @default(cuid())
  name      String        @unique // e.g. "Modeling", "Rigging", "Animation"
  createdAt DateTime      @default(now())

  people    PersonSkill[]
}

// ── PERSON SKILL ────────────────────────────────────────────────
// The live link: this person has this skill at this current rating.
// One row per person-per-skill. The `rating` is the CURRENT score;
// every change to it is also recorded in SkillRatingChange below.
model PersonSkill {
  id        String   @id @default(cuid())
  personId  String
  skillId   String
  rating    Int      // current score, 1–5 (validated in the API)

  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  history   SkillRatingChange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([personId, skillId]) // a person can't have the same skill twice
}

// ── SKILL RATING CHANGE ─────────────────────────────────────────
// The audit trail. Every score movement writes one row here:
// what it was, what it became, who did it, why (source), and when.
// The interview score is simply the FIRST row, source = INTERVIEW.
model SkillRatingChange {
  id            String       @id @default(cuid())
  personSkillId String
  oldRating     Int?         // null for the very first (interview) entry
  newRating     Int          // 1–5
  source        RatingSource
  changedBy     String?      // who made the change (free text for now; links to Person later)
  note          String?      // required by the API when source = MANUAL_ADJUSTMENT
  createdAt     DateTime     @default(now())

  personSkill   PersonSkill  @relation(fields: [personSkillId], references: [id], onDelete: Cascade)
}

// ── PROJECT ──────────────────────────────────────────────────────
// The spine of the production system. Every piece of capacity and
// every deliverable (Asset) will eventually link back to a Project.
model Project {
  id          String          @id @default(cuid())
  name        String
  client      String?         // who commissioned it (free text for now)
  quadrant    ProjectQuadrant
  priority    ProjectPriority @default(P2)
  status      ProjectStatus   @default(BRIEF)
  deadline    DateTime?

  // Who is running and managing this project.
  producerId  String?
  pmId        String?
  producer    Person?         @relation("ProducerProjects", fields: [producerId], references: [id], onDelete: SetNull)
  pm          Person?         @relation("PMProjects",       fields: [pmId],       references: [id], onDelete: SetNull)

  company     Company?        // which studio owns this project (optional)

  // Drain approval gate — both must be true before a DRAIN project is accepted.
  // Only meaningful when quadrant = DRAIN; ignored otherwise.
  drainApprovedByExec     Boolean @default(false)
  drainApprovedByProducer Boolean @default(false)

  // ── PPM recommendation inputs ────────────────────────────────
  // Captured now so every project becomes a training example for the
  // future quadrant/priority recommendation engine.
  estimatedValue    Float?     // expected revenue (£/$ — no currency enforced yet)
  estimatedDuration Int?       // length in weeks
  complexityScore   Int?       // self-assessed 1–5 (1 = simple, 5 = very complex)
  clientTier        ClientTier? // how established the relationship is
  marginTarget      Float?     // target gross margin as a percentage (0–100)

  // The client company this project belongs to (replaces free-text client field over time).
  accountId   String?
  account     Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)

  // Weekly capacity allocations for this project.
  capacityEntries Capacity[]

  // Deliverables tracked through the SOP pipeline.
  assets          Asset[]

  // The lead that originated this project (set when a won lead is converted).
  lead            Lead?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

// ── SALES ENUMS ──────────────────────────────────────────────────

// Where a lead sits in the sales pipeline.
enum LeadStatus {
  QUALIFICATION  // first contact, assessing fit
  PROPOSAL       // quote / brief sent
  NEGOTIATION    // terms being agreed
  WON            // deal confirmed
  LOST           // deal not taken forward
}

// How urgently the sales team is prioritising this lead.
enum LeadPriority {
  VERY_HIGH
  HIGH
  MEDIUM
  LOW
}

// ── ACCOUNT ──────────────────────────────────────────────────────
// A client company. Single source of truth — leads AND projects link here.
model Account {
  id          String   @id @default(cuid())
  name        String
  industry    String?  // e.g. "Advertising Agency", "Direct Client", "Event"
  size        String?  // e.g. "1-10", "11-50", "51-100", "501-1,000"
  website     String?
  address     String?
  company     Company? // which studio manages this account
  airtableId  String?  @unique // original Airtable record ID — prevents duplicate imports

  contacts  Contact[]
  leads     Lead[]
  projects  Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── CONTACT ──────────────────────────────────────────────────────
// A person at a client company. Can be linked to leads.
model Contact {
  id         String   @id @default(cuid())
  name       String
  accountId  String
  email      String?
  phone      String?
  title      String?  // job title
  department String?
  vip        Boolean  @default(false) // key decision-maker flag
  airtableId String?  @unique

  account Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  leads   Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── LEAD ─────────────────────────────────────────────────────────
// A sales opportunity. Converts to a Project when won.
model Lead {
  id             String       @id @default(cuid())
  name           String
  accountId      String?
  contactId      String?
  status         LeadStatus   @default(QUALIFICATION)
  priority       LeadPriority @default(MEDIUM)
  estimatedValue Float?
  invoicedPct    Int          @default(0) // 0 / 30 / 50 / 70 / 100
  paidPct        Int          @default(0) // 0 / 20 / 25 / 30 / 40 / 50 / 60 / 70 / 80 / 100
  paymentDate    DateTime?
  completed      Boolean      @default(false)
  notes          String?
  closedById     String?      // who won or lost this deal
  projectId      String?      @unique // set when converted to a Project
  company        Company?
  airtableId     String?      @unique

  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  closedBy  Person?  @relation("LeadClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── ASSET STAGE ──────────────────────────────────────────────────
// The SOP pipeline for a single deliverable. Stages are flexible —
// a producer can move an asset to any stage at any time.
enum AssetStage {
  BRIEF            // just created, work not started
  WIP              // in active production
  INTERNAL_REVIEW  // done, awaiting CD / director sign-off
  REVISION         // feedback received, back into production
  FINAL_DELIVERY   // approved and delivered
}

// ── CAPACITY ─────────────────────────────────────────────────────
// One row per person × project × week. This IS the Capacity Board.
// "If it's not here, it doesn't exist."
// weekStart is always the Monday of the ISO week at UTC midnight.
model Capacity {
  id         String       @id @default(cuid())
  personId   String
  projectId  String
  weekStart       DateTime     // Monday 00:00:00 UTC — normalised in the service
  role            CapacityRole
  pctWeek         Float        // percentage of the week, 1–140 (>100 = includes weekend days)
  weekendApproved Boolean      @default(false) // true when producer approved working Sat/Sun

  person     Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  // A person can only appear once per project per week.
  @@unique([personId, projectId, weekStart])
}

// ── ASSET ─────────────────────────────────────────────────────────
// One deliverable inside a project. Moves through SOP stages freely
// (no enforced sequence). CD sign-off is a soft gate at INTERNAL_REVIEW.
model Asset {
  id          String     @id @default(cuid())
  name        String                         // e.g. "Hero shot render", "Social cut 15s"
  description String?                        // optional notes / brief summary
  projectId   String
  stage       AssetStage @default(BRIEF)
  cdSignedOff Boolean    @default(false)     // CD must acknowledge at INTERNAL_REVIEW
  changedBy   String?                        // free text for now; links to Person later

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
