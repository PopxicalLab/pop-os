# Copy this file to .env and fill in your values.
# The values below match the defaults in docker-compose.yml.

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pop_os"

# ── Web server ────────────────────────────────────────────────────
PORT=3000

# ── JWT auth ──────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-this-with-a-long-random-string-in-production"

# ── Autocount Cloud accounting integration ────────────────────────
# Find these in Autocount Cloud → Settings → API Integration.
AUTOCOUNT_BASE_URL="https://accounting-api.autocountcloud.com"
AUTOCOUNT_ACCOUNT_BOOK_ID="your-account-book-id"
AUTOCOUNT_KEY_ID="your-key-id"
AUTOCOUNT_API_KEY="your-api-key"
AUTOCOUNT_DEFAULT_LOCATION="HQ"
AUTOCOUNT_DEFAULT_CREDIT_TERM="C.O.D."

# ── Airtable import (optional — only needed for one-time data migration) ──
AIRTABLE_PAT=""
